---
import { site, socials } from '../config';
const year = new Date().getFullYear();
---
<footer class="footer shell">
  <div class="links">
    {socials.map((s) => <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>)}
  </div>
  <div class="copy">&copy; {year} {site.name}</div>
</footer>

<style>
  .footer {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-block: var(--space-3) var(--space-6);
    border-top: 1px solid var(--rule);
  }
  .links { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-decoration: none;
  }
  .links a:hover { color: var(--cobalt); }
  .copy {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #a8a293;
  }
</style>
