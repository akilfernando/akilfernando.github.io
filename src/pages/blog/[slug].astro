---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HireCta from '../../components/HireCta.astro';
import { site } from '../../config';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// JSON-LD article schema so posts are eligible for rich results and carry
// a machine-readable author, the same way the homepage carries Person.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: new URL(`/blog/${post.slug}/`, Astro.site).href,
  author: { '@type': 'Person', name: site.name, url: site.url },
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.date.toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <p class="eyebrow">Blog</p>
  <div class="wayrule"></div>
  <article class="article">
    <p class="date">{fmt(post.data.date)}</p>
    <h1 class="display title">{post.data.title}</h1>
    {post.data.tags.length > 0 && (
      <ul class="tags" aria-label="Tags">
        {post.data.tags.map((t) => <li>{t}</li>)}
      </ul>
    )}
    <div class="prose">
      <Content />
    </div>
    <a class="back" href="/blog/">&#8592; All posts</a>

    <HireCta />
  </article>
</BaseLayout>

<style>
  .article { max-width: var(--measure); }
  .date { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-muted); margin-top: var(--space-2); }
  .title { font-size: clamp(2rem, 5vw, 3rem); margin-top: 4px; }
  .tags { list-style: none; padding: 0; margin-top: var(--space-2); display: flex; flex-wrap: wrap; gap: 6px; }
  .tags li {
    font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted); background: var(--paper-panel); padding: 3px 9px;
  }
  .prose { margin-top: var(--space-4); }
  .prose :global(p) { margin-bottom: var(--space-2); }
  /* magazine drop cap on the opening paragraph */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-weight: 500;
    float: left;
    font-size: 3.2em;
    line-height: 0.8;
    padding: 0.06em 0.1em 0 0;
    color: var(--cobalt);
  }
  .prose :global(h2) { font-family: var(--font-display); font-weight: 500; font-size: 1.5rem; line-height: 1.2; margin: var(--space-4) 0 var(--space-1); }
  .prose :global(h3) { font-family: var(--font-display); font-weight: 500; font-size: 1.2rem; line-height: 1.25; margin: var(--space-3) 0 var(--space-1); }
  .prose :global(a) { color: var(--cobalt); text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--cobalt-deep); }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 var(--space-2) 1.4em; padding: 0; }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(li::marker) { color: var(--ink-muted); }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--rule); margin: var(--space-4) 0; }
  .prose :global(img) { margin: var(--space-3) 0; border: 1px solid var(--rule); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: var(--space-3) 0; font-size: 0.9rem; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--rule); }
  .prose :global(th) { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); }
  .prose :global(pre) { background: var(--paper-panel); padding: var(--space-2); overflow-x: auto; margin-bottom: var(--space-2); font-size: 0.85rem; border: 1px solid var(--rule); }
  .prose :global(pre code) { background: none; padding: 0; font-size: inherit; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.875em; background: var(--paper-panel); padding: 1px 5px; }
  .prose :global(blockquote) { border-left: 2px solid var(--cobalt); padding-left: var(--space-2); margin: var(--space-2) 0; color: var(--ink-muted); font-style: italic; }
  .prose :global(blockquote p) { margin-bottom: var(--space-1); }
  .back { display: inline-block; margin-top: var(--space-6); font-family: var(--font-mono); font-size: 0.8125rem; color: var(--cobalt); text-decoration: none; }
  .back:hover { text-decoration: underline; }
</style>
