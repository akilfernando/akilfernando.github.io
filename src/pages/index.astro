---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, sections, socials } from '../config';

// JSON-LD Person schema for rich results. sameAs pulls the public profiles
// (everything that is an http link, so email is excluded).
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: 'IT Systems and Cybersecurity Lead',
  worksFor: { '@type': 'Organization', name: 'Teams Squared' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Dalhousie University' },
  sameAs: socials.filter((s) => s.href.startsWith('http')).map((s) => s.href),
};
---
<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <section class="hero">
    <p class="eyebrow">Portfolio</p>
    <div class="wayrule"></div>
    <h1 class="display name">{site.name}</h1>
    {/* Drop the trailing period so the caret reads as a live typing cursor. */}
    <p class="tag"><strong>{site.tagline}</strong> {site.taglineSub.replace(/\.$/, '')}<span class="caret" aria-hidden="true"></span></p>
    <p class="avail">Relocating to Canada, September 2026 &middot; Work permit valid to 2029 &middot; No sponsorship required</p>
  </section>

  {/* Ask box: progressive enhancement. Hidden until the router script reveals it,
      so visitors with JS off just see the index below and nothing broken. */}
  <div class="ask" id="ask-box" hidden>
    <form class="ask-form" id="ask-form" role="search">
      <label class="ask-label" for="ask-input">Ask anything about me</label>
      <div class="ask-row">
        <input
          id="ask-input"
          name="q"
          type="text"
          autocomplete="off"
          enterkeyhint="go"
          placeholder="e.g. what's your security experience?"
        />
        <button type="submit" class="ask-btn"><span class="word">Ask</span></button>
      </div>
    </form>
    <p class="ask-status" id="ask-status" role="status" aria-live="polite"></p>
    <ul class="ask-suggest" id="ask-suggest" hidden>
      {sections.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
    </ul>
  </div>

  <nav class="contents" aria-label="Sections">
    {sections.map((s, i) => (
      <a class="row" href={s.href}>
        <span class="row-n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <span class="row-t display">{s.label}</span>
        <span class="row-d">{s.blurb}</span>
        <span class="arrow" aria-hidden="true">&#8599;</span>
      </a>
    ))}
  </nav>
</BaseLayout>

<script>
  // Client-side question router. No backend, no API key: it scores the question
  // against a hand-built keyword index and navigates to the best-fit section.
  type Route = { dest: string; label: string; terms: string[] };

  // Ordered most-specific first; ties resolve to the earlier entry.
  const ROUTES: Route[] = [
    { dest: '/writing', label: 'Writing', terms: ['writing', 'write', 'writes', 'fiction', 'story', 'stories', 'creative', 'old rails', 'rails', 'novel', 'prose', 'poem', 'poetry', 'literary', 'short story'] },
    { dest: '/blog', label: 'Blog', terms: ['blog', 'notes', 'article', 'articles', 'post', 'posts', 'essay', 'essays', 'thoughts', 'wrote about', 'writes about', 'blog post'] },
    { dest: '/projects', label: 'Projects', terms: ['project', 'projects', 'built', 'build', 'building', 'made', 'make', 'app', 'apps', 'portfolio work', 'game', 'games', 'gaming', 'shooter', 'ammo', 'graphics', 'vulkan', 'opengl', 'unity', 'flight sim', 'renderer', 'render', 'lms', 'training platform', 'portal', 'client portal', 'device', 'cartcloud', 'happbit', 'ecommerce', 'e-commerce', 'demo'] },
    { dest: '/career#cv', label: 'Career, CV', terms: ['cv', 'resume', 'résumé', 'curriculum vitae', 'download cv', 'download your cv', 'download resume'] },
    { dest: '/career#skills', label: 'Career, Skills', terms: ['skill', 'skills', 'tech stack', 'technologies', 'technology', 'stack', 'tooling', 'languages', 'frameworks', 'what can you do', 'proficient', 'expertise'] },
    { dest: '/about#looking', label: 'About, Hiring', terms: ['hire', 'hiring', 'available', 'availability', 'looking for', 'open to', 'opportunity', 'opportunities', 'relocate', 'relocation', 'relocating', 'canada', 'canadian', 'visa', 'pgwp', 'work permit', 'immigration', 'sponsor', 'sponsorship', 'recruit', 'recruiter', 'job opening', 'offer'] },
    { dest: '/career', label: 'Career', terms: ['career', 'experience', 'experienced', 'work', 'works', 'working', 'job', 'jobs', 'role', 'roles', 'employer', 'company', 'teams squared', 'staffing', 'ubisoft', 'intern', 'internship', 'co-op', 'coop', 'security', 'cybersecurity', 'cyber', 'infosec', 'identity', 'iam', 'entra', 'entra id', 'azure', 'active directory', 'mfa', 'conditional access', 'iso', '27001', 'isms', 'grc', 'governance', 'compliance', 'audit', 'endpoint', 'm365', 'microsoft 365', 'ninjaone', 'bitdefender', 'education', 'study', 'studied', 'degree', 'university', 'dalhousie', 'gpa', 'graduate', 'graduated', 'certification', 'certifications', 'certified', 'sc-300', 'sc300', 'what do you do', 'for work', 'for a living', 'day job', 'professional'] },
    { dest: '/about', label: 'About', terms: ['about', 'who are you', 'who is', 'yourself', 'bio', 'biography', 'contact', 'email', 'reach you', 'reach out', 'get in touch', 'linkedin', 'github', 'itch', 'itch.io', 'hobby', 'hobbies', 'play games', 'games you play', 'playing', 'play', 'godot', 'curious', 'interests', 'person', 'introduce', 'background', 'where are you', 'from'] },
  ];

  function norm(s: string): string {
    return ' ' + s.toLowerCase().replace(/[^a-z0-9.\s]/g, ' ').replace(/\s+/g, ' ').trim() + ' ';
  }

  function scoreRoute(query: string, route: Route): number {
    const q = norm(query);
    const words = new Set(q.trim().split(' '));
    let s = 0;
    for (const term of route.terms) {
      if (term.includes(' ')) {
        if (q.includes(term)) s += 2;
      } else if (words.has(term)) {
        s += 1;
      }
    }
    return s;
  }

  function bestRoute(query: string): Route | null {
    let best: Route | null = null;
    let bestScore = 0;
    for (const r of ROUTES) {
      const sc = scoreRoute(query, r);
      if (sc > bestScore) { bestScore = sc; best = r; }
    }
    return best;
  }

  const box = document.getElementById('ask-box');
  const form = document.getElementById('ask-form') as HTMLFormElement | null;
  const input = document.getElementById('ask-input') as HTMLInputElement | null;
  const status = document.getElementById('ask-status');
  const suggest = document.getElementById('ask-suggest');

  if (box && form && input && status && suggest) {
    box.removeAttribute('hidden'); // reveal only when JS is available

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      const route = bestRoute(q);
      if (route) {
        suggest.setAttribute('hidden', '');
        status.textContent = `Taking you to ${route.label} →`;
        window.setTimeout(() => { window.location.href = route.dest; }, 350);
      } else {
        status.textContent = 'Not sure where that fits. Try one of these:';
        suggest.removeAttribute('hidden');
      }
    });
  }
</script>

<style>
  .hero { padding: var(--space-8) 0 var(--space-4); }
  .name {
    font-size: var(--fs-display);
    margin-top: var(--space-1);
  }
  .tag {
    font-size: var(--fs-md);
    color: var(--ink-muted);
    margin-top: var(--space-3);
    max-width: 34ch;
    line-height: 1.5;
  }
  .tag strong { color: var(--ink); font-weight: 500; }
  /* Availability label: understated mono line, cobalt accent. One line, no banner. */
  .avail {
    font-family: var(--font-mono); font-size: 0.6875rem; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink-muted);
    margin-top: var(--space-3);
    border-left: 2px solid var(--cobalt); padding-left: var(--space-2);
  }
  /* Blinking terminal caret: the code/techy note in the type mix. Points the
     eye toward the ask box below. */
  .caret {
    display: inline-block;
    width: 0.7ch;
    height: 2px;
    margin-left: 2px;
    background: var(--cobalt);
    vertical-align: -0.08em;
    animation: caret-blink 1.15s steps(1, end) infinite;
  }
  @keyframes caret-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .caret { animation: none; }
  }

  /* Ask box: set apart from the hero above and the index below. */
  .ask { margin: var(--space-6) 0 var(--space-8); max-width: 44rem; }
  .ask-label {
    display: block;
    font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    margin-bottom: var(--space-2);
  }
  .ask-row {
    display: flex; align-items: center; gap: var(--space-2);
    border-bottom: 1px solid var(--ink); padding-bottom: 8px;
    transition: border-color 0.15s ease;
  }
  .ask-row:focus-within { border-color: var(--cobalt); }
  #ask-input {
    flex: 1; min-width: 0; border: 0; background: transparent;
    font: inherit; font-size: 1.0625rem; color: var(--ink); padding: 4px 0;
  }
  #ask-input:focus { outline: none; }
  #ask-input::placeholder { color: var(--ink-muted); }
  .ask-row button {
    background: transparent; border: 0; cursor: pointer; line-height: 1;
    color: var(--cobalt); padding: 4px 0 4px 10px;
  }
  .ask-row button:hover { color: var(--cobalt-deep); }
  /* "Ask" text button; types itself out on hover (typewriter reveal). */
  .ask-btn .word {
    display: inline-block; overflow: hidden; white-space: nowrap;
    vertical-align: bottom; width: 3.5ch;
    border-right: 2px solid transparent;
    font-family: var(--font-mono); font-weight: 500; font-size: 0.8125rem;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .ask-btn:hover .word {
    border-right-color: currentColor;
    animation: type-ask 0.5s steps(3, end);
  }
  @keyframes type-ask { from { width: 0; } to { width: 3.5ch; } }
  @media (prefers-reduced-motion: reduce) {
    .ask-btn:hover .word { animation: none; }
  }
  .ask-status {
    font-family: var(--font-mono); font-size: 0.8125rem; color: var(--cobalt);
    margin-top: var(--space-2); min-height: 1.2em;
  }
  .ask-suggest {
    list-style: none; padding: 0; margin-top: var(--space-2);
  }
  /* Only the no-match fallback should show these; keep [hidden] working
     (a bare `display: flex` would override the hidden attribute). */
  .ask-suggest:not([hidden]) {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
  }
  .ask-suggest a {
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--cobalt); text-decoration: none;
  }
  .ask-suggest a:hover { text-decoration: underline; text-underline-offset: 3px; }

  .contents { border-top: 1px solid var(--ink); }
  .row {
    display: grid;
    grid-template-columns: 2.5rem minmax(130px, 1fr) 2fr auto;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.18s ease;
  }
  .row:hover { padding-left: 10px; }
  .row-n {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--rule);
    align-self: start;
    padding-top: 0.6rem;
  }
  .row:hover .row-n { color: var(--cobalt); }
  .row-t {
    font-size: 1.875rem;
    letter-spacing: -0.01em;
  }
  .row:hover .row-t { color: var(--cobalt); }
  .row-d { font-size: 0.9rem; color: var(--ink-muted); line-height: 1.5; }
  .arrow { font-family: var(--font-mono); font-size: 1rem; color: var(--rule); }
  .row:hover .arrow { color: var(--cobalt); }

  @media (max-width: 620px) {
    .hero { padding: var(--space-6) 0 var(--space-4); }
    .row { grid-template-columns: 1fr; gap: 4px; }
    .row-n { display: none; }
    .arrow { display: none; }
  }
</style>
