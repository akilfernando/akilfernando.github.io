---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const pieces = await getCollection('writing', ({ data }) => !data.draft);
  return pieces.map((piece) => ({ params: { slug: piece.slug }, props: { piece } }));
}

type Props = { piece: CollectionEntry<'writing'> };
const { piece } = Astro.props;
const { Content } = await piece.render();
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title={piece.data.title}
  description={piece.data.description}
  type="article"
  publishedTime={piece.data.date.toISOString()}
>
  <p class="eyebrow">Writing</p>
  <div class="wayrule"></div>
  <article class="article">
    <p class="meta">
      <span class="date">{fmt(piece.data.date)}</span>
      {piece.data.status && <span class="status">{piece.data.status}</span>}
    </p>
    <h1 class="display title">{piece.data.title}</h1>
    {piece.data.tags.length > 0 && (
      <ul class="tags" aria-label="Tags">
        {piece.data.tags.map((t) => <li>{t}</li>)}
      </ul>
    )}
    <div class="prose">
      <Content />
    </div>
    {piece.data.status === 'in progress' && (
      <p class="wip">This piece is still being written. More to come.</p>
    )}
    <a class="back" href="/writing/">&#8592; All writing</a>
  </article>
</BaseLayout>

<style>
  .article { max-width: var(--measure); }
  .meta { display: flex; align-items: baseline; gap: 10px; margin-top: var(--space-2); }
  .date { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-muted); }
  .status {
    font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--cobalt); border: 1px solid var(--rule); padding: 2px 7px;
  }
  .title { font-size: clamp(2rem, 5vw, 3rem); margin-top: 6px; }
  .tags { list-style: none; padding: 0; margin-top: var(--space-2); display: flex; flex-wrap: wrap; gap: 6px; }
  .tags li {
    font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted); background: var(--paper-panel); padding: 3px 9px;
  }
  .prose { margin-top: var(--space-4); }
  .prose :global(p) { margin-bottom: var(--space-2); }
  /* magazine drop cap on the opening paragraph */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-weight: 500;
    float: left;
    font-size: 3.2em;
    line-height: 0.8;
    padding: 0.06em 0.1em 0 0;
    color: var(--cobalt);
  }
  /* chapter headings */
  .prose :global(h2) {
    font-family: var(--font-mono); font-weight: 500; font-size: 0.75rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    margin: var(--space-6) 0 var(--space-2); padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--rule);
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(em) { font-style: italic; }
  .prose :global(blockquote) { border-left: 2px solid var(--cobalt); padding-left: var(--space-2); margin: var(--space-2) 0; color: var(--ink-muted); font-style: italic; }
  .wip {
    margin-top: var(--space-4); font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.6;
    color: var(--ink-muted); border-left: 2px solid var(--cobalt); padding-left: var(--space-2);
  }
  .back { display: inline-block; margin-top: var(--space-6); font-family: var(--font-mono); font-size: 0.8125rem; color: var(--cobalt); text-decoration: none; }
  .back:hover { text-decoration: underline; }
</style>
