---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pieces = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title="Writing" description="Fiction and other creative writing.">
  <p class="eyebrow">Writing</p>
  <div class="wayrule"></div>
  <h1 class="display h1">Stories.</h1>
  <p class="intro">A place for the writing I do off the clock. Mostly fiction, often unfinished, added
    to whenever a piece is ready to be read.</p>

  {pieces.length === 0 ? (
    <p class="empty">Nothing here yet. Add <code>.md</code> files under <code>src/content/writing/</code>.</p>
  ) : (
    <ul class="list">
      {pieces.map((p) => (
        <li class="piece">
          <a href={`/writing/${p.slug}/`}>
            <span class="meta">
              <span class="date">{fmt(p.data.date)}</span>
              {p.data.status && <span class="status" data-s={p.data.status}>{p.data.status}</span>}
            </span>
            <h2 class="display pt">{p.data.title}</h2>
            <p class="desc">{p.data.description}</p>
            {p.data.tags.length > 0 && (
              <ul class="tags" aria-label="Tags">
                {p.data.tags.map((t) => <li>{t}</li>)}
              </ul>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .h1 { font-size: clamp(2.4rem, 6vw, 3.4rem); margin-top: var(--space-1); }
  .intro { font-size: 1.0625rem; color: var(--ink-muted); line-height: 1.6; max-width: 58ch; margin-top: var(--space-2); }
  .empty { margin-top: var(--space-4); color: var(--ink-muted); }
  code { font-family: var(--font-mono); font-size: 0.85em; }
  .list { list-style: none; padding: 0; margin-top: var(--space-4); border-top: 1px solid var(--ink); }
  .piece { border-bottom: 1px solid var(--rule); }
  .piece a { display: block; padding: var(--space-3) 0; text-decoration: none; color: inherit; transition: padding-left 0.18s ease; }
  .piece a:hover { padding-left: 10px; }
  .meta { display: flex; align-items: baseline; gap: 10px; }
  .date { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-muted); }
  .status {
    font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--cobalt); border: 1px solid var(--rule); padding: 2px 7px;
  }
  .pt { font-size: 1.5rem; margin-top: 6px; }
  .piece a:hover .pt { color: var(--cobalt); }
  .desc { font-size: 0.9rem; color: var(--ink-muted); margin-top: 6px; max-width: 62ch; }
  .tags { list-style: none; padding: 0; margin-top: var(--space-2); display: flex; flex-wrap: wrap; gap: 6px; }
  .tags li {
    font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted); background: var(--paper-panel); padding: 3px 9px;
  }
</style>
